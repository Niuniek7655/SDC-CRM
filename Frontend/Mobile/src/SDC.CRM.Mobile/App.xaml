<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:SDC.CRM.Mobile"
             xmlns:converters="clr-namespace:SDC.CRM.Mobile.Presentation.Converters"
             x:Class="SDC.CRM.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <converters:BoolToOnlineStatusConverter x:Key="BoolToOnlineStatusConverter" />
            <converters:BoolToOnlineColorConverter x:Key="BoolToOnlineColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
