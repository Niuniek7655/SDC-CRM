<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:SDC.CRM.Mobile.Presentation.ViewModels"
             xmlns:contracts="clr-namespace:SDC.CRM.Mobile.Infrastructure.Api.Contracts"
             x:Class="SDC.CRM.Mobile.MainPage"
             x:DataType="viewmodels:MainPageViewModel"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Wyloguj" Command="{Binding LogoutCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="12">

        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label Text="{Binding WelcomeMessage}"
                   Style="{StaticResource SubHeadline}"
                   FontAttributes="Bold" />

            <HorizontalStackLayout Spacing="10">
                <Label Text="Status połączenia:" VerticalOptions="Center" />
                <Label Text="{Binding IsOnline, Converter={StaticResource BoolToOnlineStatusConverter}}"
                       TextColor="{Binding IsOnline, Converter={StaticResource BoolToOnlineColorConverter}}"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}" />

        <RefreshView Grid.Row="2"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Leads}">
                <CollectionView.EmptyView>
                    <Label Text="Brak leadów do wyświetlenia."
                           HorizontalTextAlignment="Center"
                           Margin="0,40,0,0" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="contracts:LeadSummaryDto">
                        <Border Padding="12" Margin="0,4" StrokeThickness="1" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding CompanyName}" FontAttributes="Bold" />
                                <Label Text="{Binding ContactName}" FontSize="13" />
                                <Label Text="{Binding ContactEmail}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                <Label Text="{Binding Status}" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>

</ContentPage>
